# Server Configuration

# Port to listen on (default: 3000)
PORT=3000

# MongoDB connection URL
# Local Docker: mongodb://mongodb:27017/ecomanage
# Production: mongodb+srv://user:password@cluster.mongodb.net/database
DATABASE_URL=mongodb://mongodb:27017/ecomanage

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_jwt_secret_here_64_hex_chars
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_64_hex_chars

# LLM Configuration
INSIGHT_LLM_PROVIDER=anthropic
INSIGHT_LLM_MODEL=claude-haiku-4-5

# LLM API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
